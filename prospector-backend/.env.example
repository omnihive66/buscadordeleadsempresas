# ─────────────────────────────────────────────
#  PROSPECTOR — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha
# ─────────────────────────────────────────────

# Porta do servidor (padrão: 3001)
PORT=3001

# ─── Agente de IA Principal ────────────────────────────────────────────────────
# NVIDIA NIM — modelo z-ai/glm4.7 (thinking habilitado)
# Obtenha sua chave em: https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# Claude (opcional — fallback se NVIDIA falhar)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Fontes de Busca ──────────────────────────────────────────────────────────
# SerpAPI — Google Search
# Obtenha sua chave em: https://serpapi.com/dashboard
SERP_API_KEY=sua_chave_serpapi_aqui

# Apify — Google Maps + LinkedIn (fonte base de dados)
# Obtenha seu token em: https://console.apify.com/account/integrations
APIFY_API_TOKEN=seu_token_apify_aqui
